<% content_for :title, "Vinyls" %>

<div class="flex justify-between items-center">
  <h1 class="text-3xl font-bold mb-4">Vinyls list</h1>
  <%= link_to "New vinyl", new_vinyl_path, class: "rounded-md px-3 py-2 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
</div>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="mb-4">
    <%= form_with(url: vinyls_path, method: :get, local: true, class: "flex gap-2") do |form| %>
      <%= form.text_field :query, placeholder: "Search for band or album", class: "border rounded px-3 py-2 w-64" %>
      <%= form.label :release, "Release:", class: "font-semibold" %>
      <%= form.number_field :release, class: "border rounded px-3 py-2 w-24" %>

      <%= form.submit "Search", class: "bg-blue-500 text-white px-2 py-2 rounded hover:bg-blue-600" %>
    <% end %>
  </div>

  <div id="vinyls" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if @vinyls.any? %>
      <% @vinyls.each do |vinyl| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render partial: "vinyl_index", locals: { vinyl: vinyl } %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", vinyl, class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
            <%= link_to "Edit", edit_vinyl_path(vinyl), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
            <%= button_to "Destroy", vinyl, method: :delete, class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No vinyls found.</p>
    <% end %>
  </div>
</div>
