<div id="<%= dom_id vinyl %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <div class="block font-medium mb-1">
      Band: <%= vinyl.band %>
    </div>
    <div>
      Album: <%= vinyl.album %>
    </div>
    <div>
      Genre: <%= vinyl.genre %>
    </div>
    <div>
      LP amount: <%= vinyl.lp_qty %>
    </div>
    <div>
      Track amount: <%= vinyl.track_qty %>
    </div>
    <div>
      Release: <%= vinyl.release %>
    </div>
    <div>
      Rate: <%= vinyl.rate %>
    </div>
  </div>
</div>
